# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# Firebase – add Web app in Console (</>), then paste from firebaseConfig. See FIREBASE_SETUP.md
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123:web:abc
# Cloud Messaging > Web Push certificates > Generate key pair
VITE_FIREBASE_VAPID_KEY=
# Realtime Database URL (Build > Realtime Database). Required for live map/ETA on order tracking.
# Deploy rules: firebase deploy --only database (use firebase-database.rules.json in this folder).
VITE_FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
